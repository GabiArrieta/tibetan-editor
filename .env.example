# =============================================================================
# Tibetan Editor — Variables de entorno
# =============================================================================
#
# Copiá este archivo como .env.local y completá con tus valores reales.
# El archivo .env.local NO debe commitearse (ya está en .gitignore).
#
# Cómo obtener estos valores:
#   1. Ir a https://supabase.com → tu proyecto → Settings → API
#   2. Copiar "Project URL" → VITE_SUPABASE_URL
#   3. Copiar "Project API Keys → anon / public" → VITE_SUPABASE_ANON_KEY
#
# IMPORTANTE: nunca uses la "service_role" key en el frontend.
# =============================================================================

# URL del proyecto Supabase
VITE_SUPABASE_URL=https://TU_PROJECT_ID.supabase.co

# Clave pública (anon/publishable) — segura para el cliente
VITE_SUPABASE_ANON_KEY=tu_anon_key_aqui

# =============================================================================
# Modo sin Supabase (local-only)
# =============================================================================
# Si estas variables no están configuradas o tienen los valores de ejemplo,
# la app funciona en modo local sin requerir autenticación.
# Los documentos se guardan en localStorage del navegador.
# =============================================================================
